# Application Configuration
SERVER_PORT=8080
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/order-service/app.log

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=order
DB_PASSWORD=order123
DB_NAME=orderdb
DB_SSLMODE=disable

# Event Bus Configuration
EVENT_BUS_TYPE=kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=order-events
KAFKA_CONSUMER_GROUP=order-projection

# OpenTelemetry Configuration (Traces)
OTEL_SERVICE_NAME=order-service
OTEL_EXPORTER_OTLP_ENDPOINT=signoz-otel-collector:4318

# SigNoz Configuration (Logs)
# Uses shared Docker network "signoz-net" to reach signoz-otel-collector container
SIGNOZ_OTLP_ENDPOINT=signoz-otel-collector:4318

# Outbox Worker Configuration
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL=1s
